      "source": [
        "# --- 8. Accuracy tables and DM tests (Tables 5.1 - 5.3)\n",
        "def rmse(a, b): return float(np.sqrt(np.mean((np.asarray(a) - np.asarray(b))**2)))\n",
        "def mae(a, b):  return float(np.mean(np.abs(np.asarray(a) - np.asarray(b))))\n",
        "def qlike_series(x_true, x_pred):\n",
        "    r = np.exp(2.0 * (np.asarray(x_true) - np.asarray(x_pred)))\n",
        "    return r - np.log(r) - 1.0\n",
        "\n",
        "def dm_test(loss1, loss2, h):\n",
        "    # H0: equal predictive accuracy. Negative DM -> model 1 better. HAC (Bartlett, h-1) + HLN correction.\n",
        "    d = np.asarray(loss1) - np.asarray(loss2)\n",
        "    n = len(d); db = d.mean()\n",
        "    var = np.sum((d - db)**2) / n\n",
        "    for k in range(1, h):\n",
        "        cov = np.sum((d[k:] - db) * (d[:-k] - db)) / n\n",
        "        var += 2.0 * (1.0 - k / h) * cov\n",
        "    dm = db / np.sqrt(var / n)\n",
        "    dm *= np.sqrt((n + 1 - 2*h + h*(h - 1)/n) / n)\n",
        "    p = 2.0 * (1.0 - stats.t.cdf(abs(dm), df=n - 1))\n",
        "    return float(dm), float(p)\n",
        "\n",
        "acc_rows, dm_rows = [], []\n",
        "for sym in DATA:\n",
        "    d = SPLITS[sym]; nva = d['nva']\n",
        "    for h in (1, 5):\n",
        "        y = d['Y'][nva:, h-1].astype(float)\n",
        "        preds = {m: PRED[sym][(m, h)] for m in ('Naive', 'HAR', 'PatchTST')}\n",
        "        for m, yp in preds.items():\n",
        "            acc_rows.append({'symbol': sym, 'index': INDICES[sym], 'h': h, 'model': m,\n",
        "                             'RMSE_logvol': round(rmse(y, yp), 4), 'MAE_logvol': round(mae(y, yp), 4),\n",
        "                             'QLIKE': round(float(np.mean(qlike_series(y, yp))), 5)})\n",
        "        for rival in ('HAR', 'Naive'):\n",
        "            se1, se2 = (y - preds['PatchTST'])**2, (y - preds[rival])**2\n",
        "            dm_se, p_se = dm_test(se1, se2, h)\n",
        "            ql1, ql2 = qlike_series(y, preds['PatchTST']), qlike_series(y, preds[rival])\n",
        "            dm_ql, p_ql = dm_test(ql1, ql2, h)\n",
        "            dm_rows.append({'symbol': sym, 'h': h, 'comparison': f'PatchTST vs {rival}',\n",
        "                            'DM_sq_log_error': round(dm_se, 3), 'p_sq_log_error': round(p_se, 4),\n",
        "                            'DM_QLIKE': round(dm_ql, 3), 'p_QLIKE': round(p_ql, 4),\n",
        "                            'n_test': len(y)})\n",
        "\n",
        "acc = pd.DataFrame(acc_rows)\n",
        "acc[acc.h == 1].to_csv(os.path.join(OUT, 'table_5_1_accuracy_h1.csv'), index=False)\n",
        "acc[acc.h == 5].to_csv(os.path.join(OUT, 'table_5_2_accuracy_h5.csv'), index=False)\n",
        "dm = pd.DataFrame(dm_rows)\n",
        "dm.to_csv(os.path.join(OUT, 'table_5_3_dm_tests.csv'), index=False)\n",
        "\n",
        "print('=== Table 5.1 (h=1) ==='); print(acc[acc.h == 1].to_string(index=False))\n",
