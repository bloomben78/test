      "cell_type": "code",
      "source": [
        "# --- 6. PatchTST: build, train, predict (Figure 5.5, Table 4.1)\n",
        "def build_model(context_len):\n",
        "    kw = dict(num_input_channels=1, context_length=int(context_len), prediction_length=H_PRED,\n",
        "              patch_length=8, patch_stride=4, d_model=64, num_attention_heads=4,\n",
        "              num_hidden_layers=3, ffn_dim=128, dropout=0.2, head_dropout=0.1,\n",
        "              pooling_type=None, channel_attention=False, loss='mse',\n",
        "              pre_norm=True, norm_type='batchnorm')\n",
        "    try:\n",
        "        cfg = PatchTSTConfig(scaling=None, **kw)     # we standardize manually outside the model\n",
        "    except Exception:\n",
        "        cfg = PatchTSTConfig(scaling=False, **kw)\n",
        "    return PatchTSTForPrediction(cfg)\n",
        "\n",
        "def make_loaders(d, context_len=None):\n",
        "    X, Y = d['X'], d['Y']\n",
        "    if context_len is not None and context_len != X.shape[1]:\n",
        "        raise ValueError('context mismatch')\n",
        "    Xs = ((X - d['mu']) / d['sd'])[..., None].astype(np.float32)\n",
        "    Ys = ((Y - d['mu']) / d['sd'])[..., None].astype(np.float32)\n",
        "    ntr, nva = d['ntr'], d['nva']\n",
        "    def mk(a, b, shuffle):\n",
        "        return DataLoader(TensorDataset(torch.from_numpy(a), torch.from_numpy(b)),\n",
        "                          batch_size=BATCH, shuffle=shuffle)\n",
        "    return mk(Xs[:ntr], Ys[:ntr], True), mk(Xs[ntr:nva], Ys[ntr:nva], False), mk(Xs[nva:], Ys[nva:], False)\n",
        "\n",
        "def run_epoch(model, dl, opt=None):\n",
        "    training = opt is not None\n",
        "    model.train(training)\n",
        "    tot, n = 0.0, 0\n",
        "    ctx = torch.enable_grad() if training else torch.no_grad()\n",
        "    with ctx:\n",
        "        for xb, yb in dl:\n",
        "            xb, yb = xb.to(DEV), yb.to(DEV)\n",
        "            out = model(past_values=xb, future_values=yb)\n",
        "            loss = out.loss\n",
        "            if training:\n",
        "                opt.zero_grad(); loss.backward(); opt.step()\n",
        "            tot += loss.item() * len(xb); n += len(xb)\n",
        "    return tot / max(n, 1)\n",
        "\n",
        "def train_model(model, tr, va, epochs=EPOCHS, patience=PATIENCE, lr=LR, verbose=True):\n",
        "    model.to(DEV)\n",
        "    opt = torch.optim.AdamW(model.parameters(), lr=lr)\n",
        "    best, wait, best_state = float('inf'), 0, None\n",
        "    hist = {'train': [], 'val': []}\n",
        "    t0 = time.perf_counter()\n",
        "    for ep in range(1, epochs + 1):\n",
        "        trl = run_epoch(model, tr, opt)\n",
        "        val = run_epoch(model, va)\n",
        "        hist['train'].append(trl); hist['val'].append(val)\n",
        "        if verbose:\n",
        "            print(f'    epoch {ep:02d}   train {trl:.4f}   val {val:.4f}')\n",
        "        if val < best - 1e-5:\n",
        "            best, wait, best_state = val, 0, copy.deepcopy(model.state_dict())\n",
        "        else:\n",
        "            wait += 1\n",
        "            if wait >= patience:\n",
        "                if verbose:\n",
        "                    print('    early stopping')\n",
        "                break\n",
        "    if best_state is not None:\n",
        "        model.load_state_dict(best_state)\n",
        "    return time.perf_counter() - t0, hist\n",
        "\n",
        "def predict(model, dl, mu, sd):\n",
        "    model.eval()\n",
        "    outs = []\n",
        "    with torch.no_grad():\n",
        "        for xb, _ in dl:\n",
        "            o = model(past_values=xb.to(DEV))\n",
        "            outs.append(o.prediction_outputs.squeeze(-1).cpu().numpy())\n",
        "    P = np.concatenate(outs, axis=0)              # (n_test, H_PRED), standardized scale\n",
        "    return P * sd + mu\n",
        "\n",
        "TRAIN_TIME, HIST_FIRST, N_PARAMS = {}, None, None\n",
        "for i, sym in enumerate(DATA):\n",
        "    d = SPLITS[sym]\n",
        "    tr, va, te = make_loaders(d)\n",
        "    torch.manual_seed(SEED)\n",
        "    model = build_model(L_CONTEXT)\n",
        "    if N_PARAMS is None:\n",
        "        N_PARAMS = sum(p.numel() for p in model.parameters())\n",
        "        print(f'PatchTST parameter count: {N_PARAMS:,}   device: {DEV}')\n",
        "    print(f'[{sym}] training...')\n",
        "    tsec, hist = train_model(model, tr, va, verbose=(i == 0))\n",
        "    TRAIN_TIME[sym] = tsec\n",
        "    if i == 0:\n",
        "        HIST_FIRST = (sym, hist)\n",
        "    P = predict(model, te, d['mu'], d['sd'])\n",
        "    PRED[sym][('PatchTST', 1)] = P[:, 0]\n",
        "    PRED[sym][('PatchTST', 5)] = P[:, 4]\n",
        "    print(f'[{sym}] done in {tsec:.1f}s  ({len(hist[\"val\"])} epochs)')\n",
        "\n",
        "# Figure 5.5 - loss curves (first index)\n",
        "sym0, hist0 = HIST_FIRST\n",
        "fig, ax = plt.subplots(figsize=(6.5, 4))\n",
        "ax.plot(hist0['train'], label='train MSE'); ax.plot(hist0['val'], label='validation MSE')\n",
        "ax.set_xlabel('Epoch'); ax.set_ylabel('MSE (standardized log vol)')\n",
        "ax.set_title(f'Figure 5.5 - PatchTST learning curves ({sym0})'); ax.legend()\n",
        "plt.tight_layout(); plt.savefig(os.path.join(OUT, 'fig_5_5_loss_curves.png'), dpi=200, bbox_inches='tight'); plt.show()\n",
        "\n",
        "t41 = pd.DataFrame([\n",
