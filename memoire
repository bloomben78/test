        "    {'parameter': 'd_model / layers / heads / ffn', 'value': '64 / 3 / 4 / 128'},\n",
        "    {'parameter': 'dropout / head_dropout', 'value': '0.2 / 0.1'},\n",
        "    {'parameter': 'norm / pre_norm', 'value': 'batchnorm / True'},\n",
