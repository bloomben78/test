      "source": [
        "# --- 7. GPU vs CPU training benchmark (RQ3) - Table 5.4, Figure 5.4\n",
        "def time_epochs(device, n_epochs=3):\n",
        "    dv = torch.device(device)\n",
        "    d = SPLITS[list(DATA)[0]]\n",
        "    Xs = ((d['X'] - d['mu']) / d['sd'])[..., None].astype(np.float32)\n",
        "    Ys = ((d['Y'] - d['mu']) / d['sd'])[..., None].astype(np.float32)\n",
        "    dl = DataLoader(TensorDataset(torch.from_numpy(Xs[:d['ntr']]), torch.from_numpy(Ys[:d['ntr']])),\n",
        "                    batch_size=BATCH, shuffle=True)\n",
        "    torch.manual_seed(SEED)\n",
        "    m = build_model(L_CONTEXT).to(dv)\n",
        "    opt = torch.optim.AdamW(m.parameters(), lr=LR)\n",
        "    times = []\n",
        "    for _ in range(n_epochs):\n",
        "        t0 = time.perf_counter()\n",
        "        m.train(True)\n",
        "        for xb, yb in dl:\n",
        "            out = m(past_values=xb.to(dv), future_values=yb.to(dv))\n",
        "            opt.zero_grad(); out.loss.backward(); opt.step()\n",
        "        if dv.type == 'cuda':\n",
        "            torch.cuda.synchronize()\n",
        "        times.append(time.perf_counter() - t0)\n",
        "    return float(np.mean(times[1:])) if len(times) > 1 else float(times[0])   # skip warm-up epoch\n",
        "\n",
        "bench = []\n",
        "if torch.cuda.is_available():\n",
        "    tg = time_epochs('cuda')\n",
        "    bench.append({'device': torch.cuda.get_device_name(0), 'sec_per_epoch': round(tg, 2)})\n",
        "    print(f'GPU: {tg:.2f} s/epoch')\n",
        "else:\n",
        "    tg = None\n",
        "    print('No CUDA device found - GPU timing skipped (enable the T4 runtime).')\n",
        "tc = time_epochs('cpu')\n",
        "bench.append({'device': f'CPU ({platform.processor() or \"Colab vCPU\"})', 'sec_per_epoch': round(tc, 2)})\n",
        "print(f'CPU: {tc:.2f} s/epoch')\n",
        "if tg:\n",
        "    speedup = tc / tg\n",
        "    bench.append({'device': 'speedup (CPU/GPU)', 'sec_per_epoch': round(speedup, 1)})\n",
        "    print(f'Speedup: {speedup:.1f}x')\n",
        "\n",
        "t54 = pd.DataFrame(bench)\n",
        "t54.to_csv(os.path.join(OUT, 'table_5_4_gpu_benchmark.csv'), index=False)\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(5.5, 3.6))\n",
        "names = [b['device'] for b in bench if 'speedup' not in b['device']]\n",
        "vals  = [b['sec_per_epoch'] for b in bench if 'speedup' not in str(b['device'])]\n",
        "ax.bar(range(len(vals)), vals, color=['seagreen', 'indianred'][:len(vals)])\n",
        "ax.set_xticks(range(len(vals))); ax.set_xticklabels(names, fontsize=7)\n",
        "ax.set_ylabel('Seconds per training epoch')\n",
        "ax.set_title('Figure 5.4 - Training cost: GPU vs CPU (same model, same data)')\n",
        "plt.tight_layout(); plt.savefig(os.path.join(OUT, 'fig_5_4_gpu_cpu.png'), dpi=200, bbox_inches='tight'); plt.show()\n",
        "t54"
