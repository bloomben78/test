        "# --- 5. Benchmark forecasts: Naive and HAR (Table 5.6 for HAR coefficients)\n",
        "PRED = {sym: {} for sym in DATA}      # PRED[sym][(model, h)] -> np.array over test windows\n",
        "\n",
        "def har_features(X):\n",
        "    return np.column_stack([X[:, -1], X[:, -5:].mean(axis=1), X[:, -22:].mean(axis=1)])\n",
        "\n",
        "har_rows = []\n",
        "for sym in DATA:\n",
        "    d = SPLITS[sym]; X, Y, ntr, nva = d['X'], d['Y'], d['ntr'], d['nva']\n",
        "    F = sm.add_constant(har_features(X))\n",
        "    for h in (1, 5):\n",
        "        y = Y[:, h-1]\n",
        "        ols = sm.OLS(y[:ntr], F[:ntr]).fit()\n",
        "        PRED[sym][('HAR', h)]   = np.asarray(ols.predict(F[nva:]))\n",
        "        PRED[sym][('Naive', h)] = X[nva:, -1].astype(float)\n",
        "        har_rows.append({'symbol': sym, 'h': h,\n",
        "                         'beta0': round(float(ols.params[0]), 4), 'beta_daily': round(float(ols.params[1]), 4),\n",
        "                         'beta_weekly': round(float(ols.params[2]), 4), 'beta_monthly': round(float(ols.params[3]), 4),\n",
        "                         'in_sample_R2': round(float(ols.rsquared), 4)})\n",
        "t56 = pd.DataFrame(har_rows)\n",
        "t56.to_csv(os.path.join(OUT, 'table_5_6_har_coefficients.csv'), index=False)\n",
        "print('HAR fitted for all indices and horizons. In-sample R2 at h=1 is typically ~0.5-0.75.')\n",
        "t56"
